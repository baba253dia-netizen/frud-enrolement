generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StatutMembre {
  EN_ATTENTE
  VALIDE
  REJETE
}

enum ModePaiement {
  BANKILY
  MASRVI
}

enum RoleAgent {
  ADMIN
  AGENT_TERRAIN
}

model Membre {
  id              String        @id @default(cuid())
  nni             String        @unique
  nomPrenom       String
  dateNaissance   DateTime
  telephone       String        @unique
  wilaya          String
  moughataa       String
  commune         String
  quartierVillage String
  modePaiement    ModePaiement
  preuvePaiement  String?
  codeAccesAgent  String
  statut          StatutMembre  @default(EN_ATTENTE)
  dateCreation    DateTime      @default(now())
  dateValidation  DateTime?
  agent           Agent?        @relation(fields: [agentId], references: [id])
  agentId         String?
  preuves         PaiementPreuve[]

  @@index([nomPrenom, dateNaissance])
}

model Agent {
  id              String      @id @default(cuid())
  email           String      @unique
  passwordHash    String
  nom             String
  role            RoleAgent   @default(AGENT_TERRAIN)
  codePin         String      @unique
  wilayaAssignee  String?
  membres         Membre[]
}

model PaiementPreuve {
  id                 String   @id @default(cuid())
  membreId           String
  membre             Membre   @relation(fields: [membreId], references: [id])
  imageUrl           String
  hashImage          String
  verificationStatus String   @default("NON_VERIFIE")
  dateUpload         DateTime @default(now())
}
